# nextcloud-nas-pull-sync config

# NAS mountpoint (NFS mounted in the VM)
NAS_MOUNT="/mnt/nas"
DATA_DIR="/mnt/nas/daten"
QUAR_DIR="/mnt/nas/quarantine"

# Minimum free space (GiB) on NAS_MOUNT before a sync starts
MIN_FREE_GIB=20

# Rclone behaviour
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=8
RCLONE_MAX_DELETE=50
RCLONE_CONTIMEOUT="15s"
RCLONE_TIMEOUT="5m"
RCLONE_RETRIES=3
RCLONE_LOW_LEVEL_RETRIES=20
RCLONE_RETRIES_SLEEP="30s"

# Nextcloud base URL
NC_BASE_URL="https://cloud.example.tld"

# Sync targets: one per line
# format: INSTANCE|REMOTE_NAME|NC_USERNAME|DEST_PATH
# - INSTANCE is used for systemd unit name (nc-pull@INSTANCE)
# - REMOTE_NAME becomes the rclone remote (webdav)
# - NC_USERNAME is the Nextcloud username (for URL + auth)
# - DEST_PATH is local target directory
SYNC_TARGETS="
#tj-doeren|nc_tj|tj.doeren|/mnt/nas/daten/tj-doeren
#h-schulze|nc_hs|h.schulze|/mnt/nas/daten/h-schulze
#em-knoche|nc_em|em.knoche|/mnt/nas/daten/em-knoche
"

# ClamAV daily full scan time (systemd OnCalendar). Example: 03:15
CLAMAV_ONCALENDAR="*-*-* 03:15:00"

# Bi-Sync interval (systemd). Example: 2h
PULL_INTERVAL="2h"
PULL_RANDOM_DELAY="5min"

# Spacecheck interval (systemd). Example: 15min
SPACECHECK_INTERVAL="15min"

